theme_override_colors/font_color = Color(0.5019608, 0.28627452, 0.14117648, 1)
theme_override_fonts/font = ExtResource("7_kbj74")
theme_override_font_sizes/font_size = 16
text = "
Traditional Maguindanao Dodol is a beloved sweet delicacy from the Maguindanao communities of Mindanao, Philippines, known for its rich caramel flavor, fragrant pandan aroma, and chewy texture shaped by hours of patient stirring. Its roots can be traced to early Maritime Southeast Asian trading cultures, where coastal communities in present-day Indonesia, Malaysia, and Brunei developed similar sticky rice sweets using palm sugar, coconut milk, and glutinous rice that spread across islands through cultural exchange. In southern Philippines, Moro communities adapted the recipe and gave it deeper meaning, making dodol an essential food during Eid celebrations, weddings, harvest gatherings, and the welcoming of honored guests. Families and neighbors traditionally gather around one large wok to stir the mixture together, transforming cooking into a shared ritual of storytelling, cooperation, and prayer that strengthens social bonds. Beyond celebration, dodol also reflects practical wisdom, as its energy-rich ingredients once helped sustain people during fasting periods and long journeys. Today, its deep brown color from caramelized palm sugar, sticky consistency from gelatinized rice starch, and warm aroma from pandan leaves continue to symbolize patience, unity, and living cultural heritage passed lovingly from one generation to the next. "
autowrap_mode = 2

[node name="RecipeBg3" type="NinePatchRect" parent="CanvasLayer/BookFrame" unique_id=1207884917]
