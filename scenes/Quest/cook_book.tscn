[node name="Label" type="Label" parent="CanvasLayer/BookFrame/RecipeBg4" unique_id=1522132351]
layout_mode = 1
anchors_preset = -1
anchor_left = 0.5
anchor_top = 0.223
anchor_right = 0.5
anchor_bottom = 0.223
offset_left = -320.5
offset_top = -151.595
offset_right = 322.5
offset_bottom = 628.405
theme_override_colors/font_color = Color(0.5019608, 0.28627452, 0.14117648, 1)
theme_override_fonts/font = ExtResource("7_kbj74")
theme_override_font_sizes/font_size = 16
text = "
3. Continuous Stirring (Gelatinization and Caramelization Phase) 
Maintain steady stirring over low to medium heat for 30–45 minutes, or until the mixture thickens. The starch undergoes gelatinization, forming the sticky and chewy consistency, while the palm sugar undergoes caramelization, producing the deep brown color and rich flavor. Continuous stirring ensures even heat distribution and prevents burning. 

4. Final Transfer 
When the mixture pulls away from the sides of the pan, remove the pandan bundle and transfer the dodol onto a banana leaf-lined tray (around 6x6 inches). Let it cool for 20–30 minutes until it sets into a firm yet chewy texture. "
autowrap_mode = 2

