[node name="Label" type="Label" parent="CanvasLayer/BookFrame/RecipeBg3" unique_id=1067592807]
layout_mode = 1
anchors_preset = -1
anchor_left = 0.5
anchor_top = 0.223
anchor_right = 0.5
anchor_bottom = 0.223
offset_left = -320.5
offset_top = -151.595
offset_right = 322.5
offset_bottom = 628.405
theme_override_colors/font_color = Color(0.5019608, 0.28627452, 0.14117648, 1)
theme_override_fonts/font = ExtResource("7_kbj74")
theme_override_font_sizes/font_size = 16
text = "
1. Dissolve the Sugar and Infuse the Pandan 
Place 1 cup (200 g) chopped palm sugar and 1 cup (240 ml) first-extract coconut milk into a large wok. Add 2–3 pandan leaves (tied into a bundle). Stir slowly over low heat until the sugar dissolves completely (about 5–8 minutes). During this stage, heat energy increases the motion of sugar molecules, allowing them to break apart and mix evenly with the coconut milk, while pandan releases aromatic compounds that diffuse into the liquid. 

2. Add the Flour Batter 
In a separate bowl, mix ¾ cup (90 g) glutinous rice flour with ½ cup (120 ml) water to form a smooth batter. Gradually pour this into the wok while continuously stirring (about 3–5 minutes) to prevent lumps. Constant motion ensures uniform suspension of particles, helping achieve a smooth texture. 
"
autowrap_mode = 2

